# ──────────────────────────────────────────────────────────────────────────────
# Intelligent University Observatory — Environment Configuration
# Copy this to .env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# ── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite (local development — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./observatory.db

# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/observatory

# ── SECURITY ─────────────────────────────────────────────────────────────────
# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# JWT token expiry in minutes (default 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT algorithm
ALGORITHM=HS256

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── APP ──────────────────────────────────────────────────────────────────────
# development | production
ENVIRONMENT=development

# ── SCRAPER ──────────────────────────────────────────────────────────────────
# mock  = returns hardcoded realistic data (recommended for development)
# live  = makes real HTTP requests to sources
SCRAPER_MODE=mock

# ── ML / RECOMMENDATION WEIGHTS ──────────────────────────────────────────────
# Must sum to 1.0
RECOMMENDATION_W1=0.5   # cosine similarity
RECOMMENDATION_W2=0.3   # academic level match
RECOMMENDATION_W3=0.2   # deadline recency
